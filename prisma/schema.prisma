// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//Enums
enum LoanStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  OVERDUE
  COMPLETED
  DEFAULTED
  CANCELLED
}

enum DocumentType {
  ID
  BANK_STATEMENT
  CONTRACT
  PAYSLIP
  OTHER
}

enum DocumentStatus {
  UPLOADED
  EXTRACTED
  FAILED
  REVIEWED
}

enum UserRole {
  ADMIN
  STAFF
}

enum LoanPenaltyType {
  INSTALLMENT_INCREASE
  FULL_REPAYMENT_DEMAND
  PERIOD_EXTENSION
}

enum LoanActivityType {
  CREATED
  UPDATED
  STATUS_UPDATED
  CONTRACT_UPLOADED
  PENALTY_APPLIED
  NOTE_ADDED
}


// CORE MODELS
model Client {
  id            String   @id @default(uuid())
  firstName     String
  empNumber      String
  email         String   @unique
  phone         String?
  idNumber      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  loans         Loan[]
  documents     Document[]
}

model Loan {
  id              String      @id @default(uuid())
  reference       String      @unique
  principal       Decimal     @db.Decimal(10, 2)
  interestRate    Decimal     @db.Decimal(5, 2)
  durationMonths  Int
  totalAmountRepayable Decimal @db.Decimal(10, 2)
  totalInterest  Decimal     @db.Decimal(10, 2)
  totalMonthlyInstallment Decimal @db.Decimal(10, 2)
  remainingAmount Decimal   @db.Decimal(10, 2)
  quantity       Int         @default(1)
  startDate       DateTime?
  endDate         DateTime?
  status          LoanStatus  @default(DRAFT)

  clientId        String
  client          Client      @relation(fields: [clientId], references: [id])

  createdById     String?
  createdBy       User?       @relation(fields: [createdById], references: [id])

  contractId      String?
  contract        Contract?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  transitions     LoanTransition[]
  penalties       LoanPenalty[]
  activities      LoanActivity[]
  assignments     LoanAssignment[]
  payments        Payment[]
  Documents       Document[]
}

model Contract {
  id          String   @id @default(uuid())
  loanId      String   @unique
  fileUrl     String
  publicId    String?
  resourceType String?
  format      String?
  signed      Boolean  @default(false)
  signedAt    DateTime?

  createdAt   DateTime @default(now())

  loan        Loan     @relation(fields: [loanId], references: [id])
}

// SUPPORTING MODELS
model Document {
  id        String @id @default(uuid())
  type      DocumentType
  fileUrl   String
  publicId  String?
  resourceType String?
  format    String?
  clientId  String?
  loanId    String?
  loan      Loan?   @relation(fields: [loanId], references: [id])
  client    Client?  @relation(fields: [clientId], references: [id])

  uploadedAt DateTime @default(now())
}

model Payment {
  id          String   @id @default(uuid())
  loanId      String
  amount      Decimal  @db.Decimal(10, 2)
  paidAt      DateTime @default(now())

  loan        Loan     @relation(fields: [loanId], references: [id])
}

// AUDIT & STATE TRACKING
model LoanTransition {
  id          String      @id @default(uuid())
  loanId      String
  fromStatus  LoanStatus
  toStatus    LoanStatus
  reason      String?
  performedBy String?

  createdAt   DateTime    @default(now())

  loan        Loan        @relation(fields: [loanId], references: [id])
}

model LoanPenalty {
  id                    String           @id @default(uuid())
  loanId                String
  type                  LoanPenaltyType
  rate                  Decimal          @db.Decimal(5, 2)
  months                Int
  baseMonthlyInstallment Decimal         @db.Decimal(10, 2)
  penaltyAmount         Decimal          @db.Decimal(10, 2)
  reason                String?
  createdAt             DateTime         @default(now())

  loan                  Loan             @relation(fields: [loanId], references: [id])

  @@index([loanId])
}

model LoanActivity {
  id          String           @id @default(uuid())
  loanId      String
  type        LoanActivityType
  details     String?
  performedBy String?
  createdAt   DateTime         @default(now())

  loan        Loan             @relation(fields: [loanId], references: [id])
  user        User?            @relation(fields: [performedBy], references: [id])

  @@index([loanId])
  @@index([performedBy])
}

// INTERNAL USERS
model User {
  id          String    @id @default(uuid())
  name        String
  email       String    @unique
  password    String
  role        UserRole  @default(STAFF)
  failedLoginAttempts Int      @default(0)
  lockoutUntil DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  sessions    Session[]
  activities  LoanActivity[]
  createdLoans Loan[]
  loanAssignments LoanAssignment[]
  passwordResetTokens PasswordResetToken[]
}

model LoanAssignment {
  id        String   @id @default(uuid())
  loanId    String
  userId    String
  createdAt DateTime @default(now())

  loan      Loan     @relation(fields: [loanId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([loanId, userId])
  @@index([loanId])
  @@index([userId])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String?
  revokedAt DateTime?
  expiresAt DateTime
  createdAt DateTime @default(now())
  lastUsedAt DateTime @default(now())

  @@index([userId])
}

model ContractTemplate {
  id           String   @id @default(uuid())
  fileUrl      String
  publicId     String?
  resourceType String?
  format       String?
  isActive     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@unique([tokenHash])
}

model LoanDraft {
  id          String   @id @default(uuid())

  clientData  Json?
  financialData Json?

  documentUrls Json?

  step        Int      @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
